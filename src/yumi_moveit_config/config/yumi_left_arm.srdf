    <end_effector name="left_gripper_ee" parent_link="gripper_l_grasp_frame" group="left_gripper" parent_group="left_arm" />
    <passive_joint name="gripper_l_joint_m" />
    <passive_joint name="gripper_l_joint" />
    <disable_collisions link1="gripper_l_base" link2="gripper_l_finger_l" reason="XRDF" />
