    <disable_collisions link1="yumi_body" link2="yumi_link_1_l" reason="XRDF" />
    <disable_collisions link1="yumi_body" link2="yumi_link_2_l" reason="XRDF" />
    <disable_collisions link1="yumi_link_1_l" link2="yumi_link_2_l" reason="XRDF" />
    <disable_collisions link1="yumi_link_2_l" link2="yumi_link_3_l" reason="XRDF" />
