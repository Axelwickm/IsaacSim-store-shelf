<?xml version="1.0" ?>
<robot name="yumi">
    <group name="left_arm">
        <chain base_link="yumi_body" tip_link="gripper_l_grasp_frame" />
    </group>
    <group name="left_gripper">
        <link name="gripper_l_finger_r" />
        <link name="gripper_l_base" />
        <link name="gripper_l_finger_l" />
